GITNEXUS_SERVER_IMAGE=ghcr.io/abhigyanpatwari/gitnexus:1.6.5
GITNEXUS_WEB_IMAGE=ghcr.io/abhigyanpatwari/gitnexus-web:1.6.5

GITNEXUS_SERVER_CONTAINER_NAME=amx_gitnexus_server
GITNEXUS_WEB_CONTAINER_NAME=amx_gitnexus_web
GITNEXUS_UID=0
GITNEXUS_GID=0

GITNEXUS_BIND_ADDRESS=127.0.0.1
GITNEXUS_WEB_BIND_ADDRESS=127.0.0.1
GITNEXUS_SERVER_HOST_PORT=4747
GITNEXUS_WEB_HOST_PORT=4173

GITNEXUS_WORKSPACE_DIR=/home/ubuntu/amx/gitnexus/workspace
GITNEXUS_REPOSITORY_PATH=/workspace/ConsultantAIP
GITNEXUS_BASE_URL=http://127.0.0.1:4747
GITNEXUS_PROVIDER_URL=http://gitnexus-server:4747
GITNEXUS_WEB_URL=http://127.0.0.1:4173
AMX_RUNTIME_NETWORK=amx_runtime_network

# Required governance note:
# The public OSS project is licensed under PolyForm Noncommercial.
# Confirm commercial/enterprise authorization before using it as internal company tooling.
GITNEXUS_LICENSE_MODE=oss-noncommercial-pending-commercial-confirmation
