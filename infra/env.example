# Consultant AI Workbench - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# ADMINISTRATION
# =============================================================================
BOOTSTRAP_ADMIN_EMAIL=admin@consultant.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-in-production
BOOTSTRAP_ADMIN_NAME=Admin

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=consultant
POSTGRES_PASSWORD=consultant123
POSTGRES_DB=consultant_ai
DATABASE_URL=postgresql+asyncpg://consultant:consultant123@postgres:5432/consultant_ai

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0
ARQ_REDIS_URL=redis://redis:6379/1

# =============================================================================
# DOCKER HOST PORTS
# =============================================================================
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
WEB_HOST_PORT=3000
API_HOST_PORT=18000

# =============================================================================
# OPENAI / LLM PROVIDER
# =============================================================================
OPENAI_BASE_URL=https://api.minimax.chat/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=MiniMax-Text-01

# =============================================================================
# WEB
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:18000/api/v1

# =============================================================================
# STORAGE
# =============================================================================
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/storage

# =============================================================================
# VECTOR STORE & SEARCH
# =============================================================================
VECTOR_STORE_PROVIDER=pgvector
SEARCH_PROVIDER=postgresql
GRAPH_STORE_PROVIDER=postgresql

# =============================================================================
# S3 COMPATIBLE OBJECT STORAGE (Optional)
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=consultant-ai-storage
# S3_ENDPOINT_URL=
# AWS_REGION=us-east-1

# =============================================================================
# OCI OBJECT STORAGE (Optional)
# =============================================================================
# OCI_CONFIG_PATH=/path/to/oci/config
# OCI_BUCKET=consultant-ai-storage
# OCI_NAMESPACE=your-namespace

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# WORKER
# =============================================================================
